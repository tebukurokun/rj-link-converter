{
  "manifest_version": 3,
  "name": "DLsite Link Converter",
  "version": "1.2",
  "description": "DLsiteの作品番号（RJ/RE/VJ/BJ）をリンクに変換し、クリック履歴をブラウザ内に記録します",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "クリック履歴"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.dlsite.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "dlsite-link-converter@tebukuro.me",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
