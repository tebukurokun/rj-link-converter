{
  "manifest_version": 3,
  "name": "DLsite RJ Link Converter",
  "version": "1.0",
  "description": "RJから始まる番号を自動的にDLsiteのリンクに変換します",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "クリック履歴"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.dlsite.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon96.png",
    "128": "icon96.png"
  }
}
